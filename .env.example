# Copy to .env for local development: cp .env.example .env
ENV=dev
PORT=8080
DATABASE_URL=postgres://postgres:postgres@postgres:5432/feature_flags?sslmode=disable
REDIS_ADDR=redis:6379
LOG_LEVEL=debug

# Host-run tooling only (tests, psql) — DATABASE_URL and REDIS_ADDR above use
# the compose-internal hostnames, which don't resolve from the host.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/feature_flags?sslmode=disable
TEST_REDIS_ADDR=localhost:6380
